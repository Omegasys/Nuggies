# =========================
# Nuggies Environment Config
# =========================

# Debug mode (true/false)
NUGGIES_DEBUG=false

# Log level: error, warn, info, debug, trace
NUGGIES_LOG_LEVEL=info

# Default package format preference
# Options: auto, flatpak, snap, appimage, native
NUGGIES_DEFAULT_FORMAT=auto

# Enable Snap support (0 = disabled, 1 = enabled)
NUGGIES_ENABLE_SNAP=0

# Offline mode (use cached metadata only)
NUGGIES_OFFLINE_MODE=0

# Path to config directory
NUGGIES_CONFIG_DIR=~/.config/nuggies

# Cache directory
NUGGIES_CACHE_DIR=~/.cache/nuggies

# Enable AI explanation system (local only)
NUGGIES_AI_ENABLED=0

# Path to local AI model (optional)
NUGGIES_AI_MODEL_PATH=

# Security strict mode (1 = paranoid, 0 = normal)
NUGGIES_STRICT_SECURITY=1

# Allow community metadata (0 = disabled, 1 = enabled)
NUGGIES_COMMUNITY_FEATURES=1

# Custom repositories (comma-separated URLs)
NUGGIES_CUSTOM_REPOS=

# Max parallel operations
NUGGIES_MAX_PARALLEL=4
