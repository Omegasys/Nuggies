# EditorConfig helps maintain consistent coding styles

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

indent_style = space
indent_size = 4

# Markdown (don’t break formatting)
[*.md]
trim_trailing_whitespace = false
indent_size = 2

# YAML / TOML configs
[*.{yml,yaml,toml}]
indent_size = 2

# Shell scripts
[*.sh]
indent_size = 2

# Rust files
[*.rs]
indent_size = 4

# Makefiles
[Makefile]
indent_style = tab
